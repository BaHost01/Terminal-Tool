{
  "name": "terminal-tool",
  "version": "3.0.0",
  "description": "Cross-platform remote terminal sharing solution. Host your terminal and connect from anywhere.",
  "keywords": [
    "terminal",
    "pty",
    "remote-access",
    "collaboration",
    "sharing",
    "windows-host",
    "relay-server"
  ],
  "homepage": "https://github.com/BaHost01/Terminal-Tool",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BaHost01/Terminal-Tool.git"
  },
  "bugs": {
    "url": "https://github.com/BaHost01/Terminal-Tool/issues"
  },
  "type": "module",
  "bin": {
    "terminal-tool": "./bin/run.js"
  },
  "files": [
    "/bin",
    "/dist",
    "/oclif.manifest.json",
    "/README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "lint": "eslint src",
    "postpack": "rm -f oclif.manifest.json",
    "prepack": "oclif manifest && oclif readme",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "oclif": {
    "bin": "terminal-tool",
    "dirname": "terminal-tool",
    "commands": "./dist/commands",
    "topicSeparator": " ",
    "topics": {
      "host": {
        "description": "Expose local terminal to the relay"
      },
      "client": {
        "description": "Connect to a remote terminal"
      },
      "list": {
        "description": "List available terminal hosts"
      }
    }
  },
  "dependencies": {
    "@oclif/core": "^4.0.0",
    "terminal-tool-protocol": "workspace:*",
    "screenshot-desktop": "^1.15.4",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@oclif/plugin-help": "^6.0.0",
    "terminal-tool-config": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/screenshot-desktop": "^1.15.0",
    "@types/ws": "^8.5.10",
    "oclif": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
