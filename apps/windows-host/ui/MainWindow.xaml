<Window x:Class="TerminalToolHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2003/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2003/xaml"
        Title="Terminal-Tool Host" Height="500" Width="650" Background="#F4F4F9"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="IconStyle" TargetType="Image">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="25">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <StackPanel Orientation="Horizontal">
                <Image Source="Resources/Icons/terminal.svg" Style="{StaticResource IconStyle}" Width="24" Height="24"/>
                <TextBlock Text="Terminal-Tool Host" Style="{StaticResource HeaderStyle}"/>
            </StackPanel>
            
            <TextBlock Text="Relay Server URL:" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="RelayUrlBox" Text="https://terminal-tool.onrender.com/" Padding="5"/>
            
            <TextBlock Text="Admin Password:" Style="{StaticResource LabelStyle}"/>
            <PasswordBox x:Name="AdminPasswordBox" Padding="5"/>
            
            <TextBlock Text="Machine Name:" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="MachineNameBox" Padding="5"/>
            
            <StackPanel Margin="0,20,0,0">
                <CheckBox x:Name="ScreenSharingCheck" Margin="0,5">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="Resources/Icons/monitor.svg" Style="{StaticResource IconStyle}"/>
                        <TextBlock Text="Enable Screen Sharing (WIP)"/>
                    </StackPanel>
                </CheckBox>
                
                <CheckBox x:Name="AdminShellCheck" Margin="0,5" Click="AdminShellCheck_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="Resources/Icons/shield.svg" Style="{StaticResource IconStyle}"/>
                        <TextBlock Text="Run Admin Shell (WIP)"/>
                    </StackPanel>
                </CheckBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,25,0,0">
                <Button x:Name="StartBtn" Content="Start Host" Width="120" Height="35" Click="StartBtn_Click" Background="#4CAF50" Foreground="White" BorderThickness="0">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="Resources/Icons/play.svg" Width="14" Height="14" Margin="0,0,5,0"/>
                                <TextBlock Text="Start Host"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
                <Button x:Name="StopBtn" Content="Stop Host" Width="120" Height="35" Margin="10,0,0,0" IsEnabled="False" Click="StopBtn_Click" Background="#F44336" Foreground="White" BorderThickness="0">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="Resources/Icons/square.svg" Width="14" Height="14" Margin="0,0,5,0"/>
                                <TextBlock Text="Stop Host"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </StackPanel>
        </StackPanel>

        <Border Grid.Column="1" Margin="20,0,0,0" Background="White" CornerRadius="8" Padding="15" BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Image Source="Resources/Icons/activity.svg" Style="{StaticResource IconStyle}"/>
                    <TextBlock Text="Statistics" FontWeight="Bold"/>
                </StackPanel>
                
                <TextBlock Text="Status:" Style="{StaticResource LabelStyle}" Margin="0"/>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,10">
                    <Image x:Name="StatusIcon" Source="Resources/Icons/circle-alert.svg" Width="14" Height="14" Margin="0,0,5,0"/>
                    <TextBlock x:Name="StatusLabel" Text="Stopped" Foreground="#888" VerticalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock Text="Active Clients:" Style="{StaticResource LabelStyle}" Margin="0"/>
                <TextBlock x:Name="ClientCountLabel" Text="0" FontSize="24" FontWeight="Bold" Margin="0,2,0,15"/>
                
                <TextBlock Text="Recent Log:" Style="{StaticResource LabelStyle}" Margin="0,10,0,5"/>
                <TextBox x:Name="LogBox" Height="180" IsReadOnly="True" VerticalScrollBarVisibility="Auto" 
                         Background="#F9F9F9" BorderThickness="0" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
